{
  "name": "@ajax-16/vit",
  "version": "0.0.31-alpha.0",
  "description": "Interactive CLI to manage versions, changelogs and deployments — monorepo ready",
  "keywords": [
    "cli",
    "release",
    "changelog",
    "versioning",
    "monorepo",
    "conventional-commits",
    "semantic-versioning",
    "semver",
    "deployment",
    "developer-tools",
    "git",
    "nodejs",
    "interactive",
    "rollback"
  ],
  "type": "module",
  "main": "index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajax-16/vit.git"
  },
  "author": "ajax-16",
  "bugs": {
    "url": "https://github.com/ajax-16/vit/issues"
  },
  "homepage": "https://github.com/ajax-16/vit#readme",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "vit": "index.js"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "inquirer": "^9.3.7",
    "ora": "^8.1.1",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^chalk$": "<rootDir>/tests/__mocks__/chalk.js",
      "^ora$": "<rootDir>/tests/__mocks__/ora.js",
      "^inquirer$": "<rootDir>/tests/__mocks__/inquirer.js"
    },
    "transform": {},
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "clearMocks": true,
    "collectCoverageFrom": [
      "lib/**/*.js"
    ]
  }
}
