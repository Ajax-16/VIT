{
  "changelog": {
    "path": "./CHANGELOG.md",
    "title": "Changelog",
    "semantic": true
  },
  "git": {
    "defaultCommitMessage": "chore: update",
    "releaseCommitMessage": "chore: release",
    "changelogCommitMessage": "docs: update changelog",
    "strict": true,
    "releaseBranches": ["main"],
    "preReleaseBranches": [
      { "name": "beta" },
      { "name": "alpha", "id": "alpha" },
      { "name": "next",  "id": "rc" }
    ]
  },
  "vcs": {
    "provider": "git"
  },
  "envFile": ".env",
  "projects": [
    {
      "id": "vit",
      "label": "VIT",
      "path": ".",
      "tagPrefix": "v"
    }
  ],
  "preActions": [
    {
      "id": "testing",
      "label": "Tests execution",
      "on": ["commit", "release"],
      "continueOnError": false,
      "showOutput": true,
      "command": "npm run test"
    }
  ],
  "postActions": [
    {
      "id": "release-summary",
      "label": "Release summary",
      "on": ["release"],
      "continueOnError": false,
      "showOutput": true,
      "env": {
        "URL": "http://${name}.com/${version}"
      },
      "command": "node -e \"console.log('\\n  🎉 Released!\\n  Version  : ${version.vit}\\n  Tag      : ${last_tag}\\n  URL    : ${URL}\\n  Date     : ${date}\\n')\""
    }
  ]
}