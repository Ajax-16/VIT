{
  "changelog": {
    "path": "./CHANGELOG.md",
    "title": "Changelog"
  },
  "git": {
    "defaultCommitMessage": "chore: update",
    "releaseCommitMessage": "chore: release",
    "changelogCommitMessage": "docs: update changelog",
    "strict": true,
    "releaseBranches": ["main"]
  },
  "vcs": {
    "provider": "git"
  },
  "envFile": ".env",
  "projects": [
    {
      "id": "vit",
      "label": "VIT",
      "path": ".",
      "tagPrefix": "v"
    }
  ],
  "preActions": [
    {
      "id": "preflight",
      "label": "Preflight checks",
      "on": ["commit", "release"],
      "continueOnError": false,
      "showOutput": true,
      "pipeline": [
        {
          "id": "node-version",
          "command": "node -e \"process.stdout.write(process.versions.node)\"",
          "captureAs": "NODE_VERSION"
        },
        {
          "id": "git-branch",
          "command": "git rev-parse --abbrev-ref HEAD",
          "captureAs": "GIT_BRANCH"
        },
        {
          "id": "git-author",
          "command": "git config user.name",
          "captureAs": "GIT_AUTHOR"
        },
        {
          "id": "current-version",
          "command": "node -e \"process.stdout.write(require('./package.json').version)\"",
          "captureAs": "CURRENT_VERSION"
        }
      ],
      "command": "node -e \"console.log('\\n  📋 Preflight\\n  Node     : ${NODE_VERSION}\\n  Branch   : ${GIT_BRANCH}\\n  Author   : ${GIT_AUTHOR}\\n  Version  : ${CURRENT_VERSION}\\n  Env      : ${APP_ENV}\\n')\""
    }
  ],
  "postActions": [
    {
      "id": "release-summary",
      "label": "Release summary",
      "on": ["commit", "release"],
      "continueOnError": false,
      "showOutput": true,
      "pipeline": [
        {
          "id": "new-version",
          "command": "node -e \"process.stdout.write(require('./package.json').version)\"",
          "captureAs": "NEW_VERSION"
        },
        {
          "id": "last-tag",
          "command": "git describe --tags --abbrev=0",
          "captureAs": "LAST_TAG",
          "continueOnError": true
        },
        {
          "id": "commit-count",
          "command": "git rev-list ${LAST_TAG}..HEAD --count",
          "captureAs": "COMMIT_COUNT",
          "continueOnError": true
        },
        {
          "id": "release-date",
          "command": "node -e \"process.stdout.write(new Date().toISOString().slice(0,10))\"",
          "captureAs": "RELEASE_DATE"
        }
      ],
      "command": "node -e \"console.log('\\n  🎉 Released!\\n  Version  : ${NEW_VERSION}\\n  Tag      : ${LAST_TAG}\\n  Commits  : ${COMMIT_COUNT}\\n  Date     : ${RELEASE_DATE}\\n')\""
    }
  ]
}
